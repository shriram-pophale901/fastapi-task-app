{
  "info": {
    "name": "Scalable REST API - Task Manager",
    "description": "Complete API collection for the FastAPI Task Management System with JWT Authentication and Role-Based Access Control.\n\n**How to use:**\n1. Run the `Register User` or `Login` request first.\n2. Copy the `access_token` from the response.\n3. In Postman, go to the Collection → Variables and paste it as the `token` value.\n4. All other requests will use it automatically.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PASTE_YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "User registration and login endpoints.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"full_name\": \"Test User\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Register a new user. Role can be 'user' or 'admin'.\n\n**Returns:** User details (no password)."
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"adminuser\",\n  \"email\": \"admin@example.com\",\n  \"full_name\": \"Admin User\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Register a user with admin role. Admins can see and manage ALL tasks."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "testuser",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                }
              ]
            },
            "description": "Login with username and password (OAuth2 form format).\n\n**Returns:** `access_token` (JWT) and `token_type`.\n\nCopy the `access_token` and paste it into the Collection Variable named `token`."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "CRUD endpoints for Tasks. All require a valid JWT token in the Authorization header.",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ""]
            },
            "description": "Get all tasks.\n\n- **USER role**: Returns only their own tasks.\n- **ADMIN role**: Returns ALL tasks from all users.\n\n🔒 Requires JWT token."
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task\",\n  \"description\": \"This is a sample task created via API.\",\n  \"status\": \"pending\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create a new task. The task is automatically assigned to the logged-in user.\n\n`status` can be: `pending`, `in-progress`, or `completed`.\n\n🔒 Requires JWT token."
          }
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "1"]
            },
            "description": "Get a specific task by its ID.\n\n- Users can only get their own tasks.\n- Admins can get any task.\n\n🔒 Requires JWT token."
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"status\": \"in-progress\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Update a task (partial update supported — only send fields you want to change).\n\n- Users can only update their own tasks.\n- Admins can update any task.\n\n🔒 Requires JWT token."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "1"]
            },
            "description": "Delete a task by ID.\n\n- Users can only delete their own tasks.\n- Admins can delete any task.\n\n🔒 Requires JWT token."
          }
        }
      ]
    }
  ]
}
